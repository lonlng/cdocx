@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find required dependencies
find_dependency(pugixml REQUIRED)

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/cdocx-targets.cmake")

# Check that all required components are available
check_required_components(cdocx)

# Set variables for backwards compatibility
set(CDOCX_FOUND TRUE)
set(CDOCX_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")
set(CDOCX_LIBRARIES cdocx::cdocx)

# Provide additional information
set(CDOCX_VERSION "@PROJECT_VERSION@")
set(CDOCX_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(CDOCX_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(CDOCX_VERSION_PATCH @PROJECT_VERSION_PATCH@)

# Print status message (optional)
if(NOT cdocx_FIND_QUIETLY)
    message(STATUS "Found CDocx: ${CDOCX_VERSION}")
    message(STATUS "  Include dirs: ${CDOCX_INCLUDE_DIRS}")
    message(STATUS "  Libraries: ${CDOCX_LIBRARIES}")
endif()
