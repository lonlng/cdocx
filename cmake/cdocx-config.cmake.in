@PACKAGE_INIT@

get_filename_component(CDOCX_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_CMAKE_DIR}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_PREFIX}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_PREFIX}" PATH)

# Include the targets file generated by install(EXPORT ...)
include("${CDOCX_CMAKE_DIR}/cdocx-targets.cmake")

# When cdocx is installed, its bundled dependencies (zip, pugixml) are
# exported in the same export set with namespace "cdocx::".  Create
# aliases so consumers can reference them by their original names.
if(TARGET cdocx::zip AND NOT TARGET zip::zip)
    add_library(zip::zip INTERFACE IMPORTED)
    set_property(TARGET zip::zip PROPERTY INTERFACE_LINK_LIBRARIES cdocx::zip)
endif()

if(TARGET cdocx::pugixml AND NOT TARGET pugixml::pugixml)
    add_library(pugixml::pugixml INTERFACE IMPORTED)
    set_property(TARGET pugixml::pugixml PROPERTY INTERFACE_LINK_LIBRARIES cdocx::pugixml)
endif()

check_required_components(cdocx)
