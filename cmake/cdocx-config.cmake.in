@PACKAGE_INIT@

get_filename_component(CDOCX_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_CMAKE_DIR}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_PREFIX}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_PREFIX}" PATH)

# Include the targets file generated by install(EXPORT ...)
include("${CDOCX_CMAKE_DIR}/cdocx-targets.cmake")

# Create imported targets for bundled dependencies if not already available.
# pugixml and zip are FetchContent dependencies; their headers are installed
# alongside cdocx headers and their libraries are installed to lib/.
if(NOT TARGET pugixml::pugixml)
    find_library(CDOCX_PUGIXML_LIBRARY
        NAMES pugixml pugixml-static
        PATHS "${CDOCX_PREFIX}/lib"
        NO_DEFAULT_PATH
    )
    if(CDOCX_PUGIXML_LIBRARY)
        add_library(pugixml::pugixml STATIC IMPORTED)
        set_target_properties(pugixml::pugixml PROPERTIES
            IMPORTED_LOCATION "${CDOCX_PUGIXML_LIBRARY}"
            INTERFACE_INCLUDE_DIRECTORIES "${CDOCX_PREFIX}/include"
        )
    endif()
endif()

if(NOT TARGET zip::zip)
    find_library(CDOCX_ZIP_LIBRARY
        NAMES zip zip-static
        PATHS "${CDOCX_PREFIX}/lib"
        NO_DEFAULT_PATH
    )
    if(CDOCX_ZIP_LIBRARY)
        add_library(zip::zip STATIC IMPORTED)
        set_target_properties(zip::zip PROPERTIES
            IMPORTED_LOCATION "${CDOCX_ZIP_LIBRARY}"
            INTERFACE_INCLUDE_DIRECTORIES "${CDOCX_PREFIX}/include"
        )
    endif()
endif()

# Wire bundled dependencies into the cdocx target so consumers
# only need `target_link_libraries(... cdocx::cdocx)`.
if(TARGET pugixml::pugixml AND TARGET cdocx::cdocx)
    set_property(TARGET cdocx::cdocx APPEND PROPERTY
        INTERFACE_LINK_LIBRARIES pugixml::pugixml)
endif()
if(TARGET zip::zip AND TARGET cdocx::cdocx)
    set_property(TARGET cdocx::cdocx APPEND PROPERTY
        INTERFACE_LINK_LIBRARIES zip::zip)
endif()

check_required_components(cdocx)
