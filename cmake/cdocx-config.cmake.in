@PACKAGE_INIT@

get_filename_component(CDOCX_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_CMAKE_DIR}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_PREFIX}" PATH)
get_filename_component(CDOCX_PREFIX "${CDOCX_PREFIX}" PATH)

# Include the targets file generated by install(EXPORT ...).
# This defines cdocx::cdocx but does not include bundled dependencies
# because $<BUILD_INTERFACE:> evaluates to empty in the install context.
include("${CDOCX_CMAKE_DIR}/cdocx-targets.cmake")

# ---------------------------------------------------------------------------
# Wire bundled dependency libraries into cdocx::cdocx.
#
# cdocx bundles pugixml and zip.  During the build they are linked via
# $<BUILD_INTERFACE:> generator expressions, but those expressions are
# empty for installed packages.  We therefore locate the installed
# library files here and append them to cdocx::cdocx so that consumers
# only need:
#
#   find_package(cdocx REQUIRED)
#   target_link_libraries(my_app PRIVATE cdocx::cdocx)
# ---------------------------------------------------------------------------

# Locate zip library
set(CDOCX_ZIP_LIB "")
foreach(_name zip.lib libzip.a libzip.so libzip.dylib)
    if(EXISTS "${CDOCX_PREFIX}/lib/${_name}")
        set(CDOCX_ZIP_LIB "${CDOCX_PREFIX}/lib/${_name}")
        break()
    endif()
endforeach()

# Locate pugixml library
set(CDOCX_PUGIXML_LIB "")
foreach(_name pugixml.lib libpugixml.a libpugixml.so libpugixml.dylib)
    if(EXISTS "${CDOCX_PREFIX}/lib/${_name}")
        set(CDOCX_PUGIXML_LIB "${CDOCX_PREFIX}/lib/${_name}")
        break()
    endif()
endforeach()

# Create imported targets for bundled dependencies (if libraries were found)
if(CDOCX_ZIP_LIB AND NOT TARGET cdocx::zip)
    add_library(cdocx::zip UNKNOWN IMPORTED)
    set_target_properties(cdocx::zip PROPERTIES
        IMPORTED_LOCATION "${CDOCX_ZIP_LIB}"
        INTERFACE_INCLUDE_DIRECTORIES "${CDOCX_PREFIX}/include"
    )
endif()

if(CDOCX_PUGIXML_LIB AND NOT TARGET cdocx::pugixml)
    add_library(cdocx::pugixml UNKNOWN IMPORTED)
    set_target_properties(cdocx::pugixml PROPERTIES
        IMPORTED_LOCATION "${CDOCX_PUGIXML_LIB}"
        INTERFACE_INCLUDE_DIRECTORIES "${CDOCX_PREFIX}/include"
    )
endif()

# Append bundled dependencies to cdocx::cdocx so consumers get them transitively.
if(TARGET cdocx::zip)
    set_property(TARGET cdocx::cdocx APPEND PROPERTY INTERFACE_LINK_LIBRARIES cdocx::zip)
endif()
if(TARGET cdocx::pugixml)
    set_property(TARGET cdocx::cdocx APPEND PROPERTY INTERFACE_LINK_LIBRARIES cdocx::pugixml)
endif()

check_required_components(cdocx)
